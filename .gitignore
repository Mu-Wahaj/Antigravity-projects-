# Root-level ignore rules for the antigravity projects monorepo

# Dependency directories
node_modules/

# Build output
/dist
/build
/out
/.cache

# Environment files
.env
.env.*

# Log files
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# MacOS and Windows
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Temporary files
*.tmp
*.temp

# OS generated files
ehthumbs.db
Icon?

# Ignore project-specific local files
*.local
